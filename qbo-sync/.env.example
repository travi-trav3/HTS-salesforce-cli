# ----------------------------------------------------------------------------
# hts-qbo-sync environment configuration
# Copy to .env for local dev. In production these are set via `fly secrets set`.
# Never commit a populated .env — it contains live credentials.
# ----------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Postgres (pg-boss + app tables share this database)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hts_qbo_sync

# --- QuickBooks Online ------------------------------------------------------
# QBO_ENV controls which Intuit base URL is used:
#   sandbox    -> https://sandbox-quickbooks.api.intuit.com
#   production -> https://quickbooks.api.intuit.com
# Build and test against sandbox first; flip to production only after an
# end-to-end sandbox->SF test passes.
QBO_ENV=sandbox
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REALM_ID=
# Webhook verifier token from the Intuit app's Webhooks settings.
QBO_WEBHOOK_VERIFIER_TOKEN=
# Name of the QBO Invoice custom field that holds the PO number.
QBO_PO_FIELD_NAME=PO Number
# Optional: pin the custom field by its stable DefinitionId. If set, this
# takes precedence over QBO_PO_FIELD_NAME (which is user-editable in QBO).
QBO_PO_FIELD_DEFINITION_ID=

# --- Salesforce (JWT Bearer Flow) -------------------------------------------
# No refresh token / no user click: server-to-server via Connected App + cert.
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_USERNAME=qbo-sync@htsworkforce.com
# Path to the PEM private key whose public cert is uploaded to the Connected App.
SF_JWT_KEY_PATH=./secrets/sf-jwt.key

# --- Operational notifications ----------------------------------------------
# Technical failures (dead-letter, SF API down) email this address.
OPS_ALERT_EMAIL=
# CDC poller cadence (cron). Default: every 5 minutes.
CDC_POLL_CRON=*/5 * * * *
# Overlap window (seconds) subtracted from the high-water mark on each CDC
# poll, to defend against clock skew. Idempotency dedups the overlap.
CDC_LOOKBACK_OVERLAP_SECONDS=60
